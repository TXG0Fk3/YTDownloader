<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="YTDownloader.Views.Dialogs.SettingsDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:local="using:YTDownloader.Views.Dialogs"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
               xmlns:ui="using:CommunityToolkit.WinUI"
               Title="Settings"
               CloseButtonText="Close"
               Style="{StaticResource DefaultContentDialogStyle}"
               mc:Ignorable="d">
    <ContentDialog.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>

        <Style x:Key="SettingsSectionHeaderTextBlockStyle" BasedOn="{StaticResource BodyStrongTextBlockStyle}" TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </ContentDialog.Resources>

    <ScrollViewer Height="430">
        <Grid Width="342">
            <StackPanel HorizontalAlignment="Stretch" Spacing="{StaticResource SettingsCardSpacing}">
                <StackPanel.ChildrenTransitions>
                    <EntranceThemeTransition FromVerticalOffset="50" />
                    <RepositionThemeTransition IsStaggeringEnabled="False" />
                </StackPanel.ChildrenTransitions>

                <!--  Appearance Section  -->
                <TextBlock Margin="1,0,0,6" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                    <Span><Bold>Appearance</Bold></Span>
                </TextBlock>
                <toolkit:SettingsExpander Grid.Row="1"
                                          HorizontalAlignment="Stretch"
                                          Description="Select the application theme"
                                          Header="Application Theme"
                                          HeaderIcon="{ui:FontIcon Glyph=}">
                    <toolkit:SettingsExpander.Items>
                        <toolkit:SettingsCard>
                            <RadioButtons ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}" SelectedItem="{Binding SelectedThemeMode, Mode=TwoWay}" SelectionChanged="RadioButtons_SelectionChanged" />
                        </toolkit:SettingsCard>
                    </toolkit:SettingsExpander.Items>
                </toolkit:SettingsExpander>

                <!--  Performance Section  -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                    <Span><Bold>Performance</Bold></Span>
                </TextBlock>
                <toolkit:SettingsCard Description="Limit how many videos can be downloaded at the same time. Needs restart to take effect." Header="Max Concurrent Downloads" HeaderIcon="{ui:FontIcon Glyph=&#xE896;}">
                    <NumberBox Maximum="{x:Bind ViewModel.MaxConcurrentDownloadsMaximum}"
                               Minimum="1"
                               SpinButtonPlacementMode="Inline"
                               Value="{x:Bind ViewModel.MaxConcurrentDownloads, Mode=TwoWay}" />
                </toolkit:SettingsCard>
                <toolkit:SettingsCard Description="Maximum parallel requests when loading a playlist. Higher values may be faster but can cause throttling or IP ban" Header="Max Concurrent Playlist Info Fetches" HeaderIcon="{ui:FontIcon Glyph=&#xE8B1;}">
                    <NumberBox Maximum="{x:Bind ViewModel.MaxConcurrentPlaylistFetchesMaximum}"
                               Minimum="1"
                               SpinButtonPlacementMode="Inline"
                               Value="{x:Bind ViewModel.MaxConcurrentPlaylistFetches, Mode=TwoWay}" />
                </toolkit:SettingsCard>

                <!--  Files Section  -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                    <Span><Bold>Files</Bold></Span>
                </TextBlock>
                <toolkit:SettingsExpander Grid.Row="3"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Default folder and save behavior"
                                          Header="Downloads"
                                          HeaderIcon="{ui:FontIcon Glyph=}">
                    <toolkit:SettingsExpander.Items>
                        <toolkit:SettingsCard Description="{x:Bind ViewModel.DefaultDownloadsPath, Mode=OneWay}" Header="Default Downloads Folder">
                            <Button Grid.Column="1" Command="{x:Bind ViewModel.SelectDefaultDownloadsFolderCommand}" Content="Select Folder" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Description="Ask for a save location before each download" Header="Always ask where to save files">
                            <ToggleSwitch Grid.Row="1"
                                          Grid.Column="1"
                                          IsOn="{x:Bind ViewModel.AlwaysAskWhereSave, Mode=TwoWay}"
                                          OffContent="Off"
                                          OnContent="On" />
                        </toolkit:SettingsCard>
                    </toolkit:SettingsExpander.Items>
                </toolkit:SettingsExpander>

                <!--  About Section  -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                    <Span><Bold>About</Bold></Span>
                </TextBlock>
                <toolkit:SettingsExpander Grid.Row="3"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="© 2026 TXG0Fk3. Licensed under GPL-3.0."
                                          Header="YT Downloader"
                                          HeaderIcon="{ui:BitmapIcon Source=ms-appx:///Assets/Square44x44Logo.altform-lightunplated_targetsize-32.png}">
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsTextSelectionEnabled="True">
                        <Run>Version</Run>
                        <Run Text="{x:Bind ViewModel.YTDownloaderVersion, Mode=OneTime}" />
                    </TextBlock>
                    <toolkit:SettingsExpander.Items>
                        <!--  Project links  -->
                        <toolkit:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                            <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                <HyperlinkButton Content="Project Repository" NavigateUri="https://github.com/TXG0Fk3/YTDownloader" />
                                <HyperlinkButton Content="License (GPL-3.0)" NavigateUri="https://github.com/TXG0Fk3/YTDownloader/blob/master/LICENSE" />
                                <HyperlinkButton Content="Check for Updates" NavigateUri="https://github.com/TXG0Fk3/YTDownloader/releases" />
                            </StackPanel>
                        </toolkit:SettingsCard>

                        <!--  Feedback links  -->
                        <toolkit:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                            <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                <HyperlinkButton Content="Send Feedback" NavigateUri="https://github.com/TXG0Fk3/YTDownloader/issues" />
                            </StackPanel>
                        </toolkit:SettingsCard>

                        <!--  Developer links  -->
                        <toolkit:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                            <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                <HyperlinkButton Content="TXG0Fk3 GitHub" NavigateUri="https://github.com/TXG0Fk3" />
                            </StackPanel>
                        </toolkit:SettingsCard>
                    </toolkit:SettingsExpander.Items>
                </toolkit:SettingsExpander>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</ContentDialog>
