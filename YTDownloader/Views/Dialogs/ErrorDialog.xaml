<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="YTDownloader.Views.Dialogs.ErrorDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:local="using:YTDownloader.Views.Dialogs"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               CloseButtonText="Close"
               Style="{StaticResource DefaultContentDialogStyle}"
               mc:Ignorable="d">
    <ContentDialog.Title>
        <StackPanel Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="24" Glyph="&#xEA39;" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Error" />
        </StackPanel>
    </ContentDialog.Title>

    <StackPanel Width="324" MaxHeight="430" Spacing="6">
        <ScrollViewer>
            <TextBlock x:Name="ErrorTextBlock"
                       IsTextSelectionEnabled="True"
                       TextAlignment="Justify"
                       TextWrapping="Wrap" />
        </ScrollViewer>
        <HyperlinkButton Content="Report Error" NavigateUri="https://github.com/TXG0Fk3/YT-Downloader/issues" />
    </StackPanel>
</ContentDialog>
